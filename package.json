{
  "name": "@qubit-ltd/vite-plugin-babel",
  "version": "1.6.6",
  "description": "A simple vite plugin to support Babel.",
  "author": "Haixing Hu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubit-ltd/vite-plugin-babel.git"
  },
  "bugs": {
    "url": "https://github.com/qubit-ltd/vite-plugin-babel/issues"
  },
  "homepage": "https://github.com/qubit-ltd/vite-plugin-babel",
  "keywords": [
    "vite",
    "vite-plugin",
    "babel"
  ],
  "main": "dist/vite-plugin-babel.cjs",
  "module": "dist/vite-plugin-babel.mjs",
  "exports": {
    ".": {
      "require": "./dist/vite-plugin-babel.cjs",
      "import": "./dist/vite-plugin-babel.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "doc/**/*",
    "LICENSE",
    "README.md",
    "README.zh_CN.md"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rvf dist",
    "lint": "eslint ./src",
    "build": "node esbuild.mjs",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "deploy": "npm run lint && npm run build && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "dependencies": {
    "@babel/core": "^7.29.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "yarn@4.12.0"
}
